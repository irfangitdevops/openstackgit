# Get this token from: Cloudflare Zero Trust → Access → Tunnels → openstackgit → Configure → Install connector
CLOUDFLARE_TUNNEL_TOKEN=paste_your_tunnel_token_here

# Google AdSense publisher ID — from AdSense → Sites → your site → verification code
# Must be set at DOCKER BUILD time (it's inlined into the client bundle), not just at runtime.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# OPTIONAL — GitHub personal access token (classic, no scopes / "public_repo" is plenty).
# Raises the GitHub API rate limit used by the /downloads tool pages from 60/hr to
# 5000/hr so live version histories always load. Runtime-only (never baked into the image).
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# SMTP for the Contact form / chatbox / lead popup. Runtime-only (never baked into the image).
# NOTE: Microsoft 365 disables SMTP AUTH by default per-mailbox. If sends fail with an auth
# error, enable it at: Exchange admin center → Recipients → Mailboxes → your mailbox →
# Manage email apps → turn on "Authenticated SMTP".
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=hello@yourdomain.com
SMTP_PASS=paste_your_mailbox_password_here
CONTACT_TO_EMAIL=hello@yourdomain.com
